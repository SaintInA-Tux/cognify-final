# ── Cognify .env ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your DeepSeek API key.
# Everything else works out of the box on Windows with no extra installs.

# Core
APP_ENV=development
DEBUG=true
SECRET_KEY=changeme-replace-in-production

# Database — SQLite by default (zero setup, file created automatically)
# Switch to PostgreSQL when you're ready:
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/cognify
DATABASE_URL=sqlite+aiosqlite:///./cognify.db

# Redis — disabled by default (no install needed)
# Set REDIS_ENABLED=true and make sure Redis is running to enable caching
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# DeepSeek — get your key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# MathPix OCR — only needed for image upload feature, leave blank to skip
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Cache TTLs (seconds)
CLASSIFICATION_CACHE_TTL=86400
HINT_SESSION_TTL=3600
